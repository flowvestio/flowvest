// assets/app/ui.js
(function(){
  function $(id){ return document.getElementById(id); }

  function setText(id, v){
    const el = $(id);
    if (el) el.textContent = (v == null ? "—" : String(v));
  }

  function shortAddr(a){
    if (!a) return "—";
    return a.slice(0,6) + "..." + a.slice(-4);
  }

  function fmtUnits(x, dec){
    try { return window.ethers.utils.formatUnits(x, dec); }
    catch { return "0"; }
  }

  function setConnected(connected){
    const btnC = $("btnConnect");
    const btnD = $("btnDisconnect");
    const btnClaim = $("btnClaim");
    if (btnC) btnC.disabled = !!connected;
    if (btnD) btnD.disabled = !connected;
    if (btnClaim) btnClaim.disabled = !connected;

    // creator UI reset on disconnect
    if (!connected){
      const btnCreator = $("btnCreator");
      if (btnCreator) btnCreator.classList.add("hidden");
      const panel = $("creatorPanel");
      if (panel) panel.classList.add("hidden");
    }
  }

  const logLines = [];
  function log(msg){
    const box = $("logBox");
    if (!box) return;
    const t = new Date().toLocaleTimeString();
    logLines.push(`[${t}] ${msg}`);
    if (logLines.length > 30) logLines.shift();
    box.textContent = logLines.join("\n");
    box.scrollTop = box.scrollHeight;
  }

  window.UI = {
    $, setText, shortAddr, fmtUnits, setConnected, log
  };
})();
